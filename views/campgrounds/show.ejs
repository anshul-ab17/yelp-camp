<% layout('layouts/boilerplate')%>
<link rel="stylesheet" href="/stylesheets/stars.css">

<div class="row">
    <div class="col-lg-6 col-12">
        <div id="campgroundCarousel" class="carousel slide carousel-show" data-bs-ride="carousel">
            <div class="carousel-inner">
                <% campground.images.forEach((img, i) => {  %>
                <div class="carousel-item <%= i === 0 ? 'active' : ''%>">
                    <img src="<%= img.url%>" class="d-block w-100" alt="">
                </div>
                <% }) %>
            </div>
            <% if(campground.images.length > 1) {%>
            <button class="carousel-control-prev" type="button" data-bs-target="#campgroundCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#campgroundCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
            <% } %>
        </div>

        <div class="card-custom card p-4 mb-4">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                <h1 class="show-title m-0"><%= campground.title%></h1>
                <div class="show-price">$<%= campground.price%><span style="font-size: 1rem; font-weight: normal; color: var(--text-muted);">/night</span></div>
            </div>
            
            <div class="show-meta">
                <span><i class="fa-solid fa-location-dot text-danger"></i> <%= campground.location%></span>
                <span><i class="fa-solid fa-user text-primary"></i> Submitted by <%= campground.author.username%></span>
            </div>

            <p class="card-text fs-5" style="line-height: 1.6; color: var(--text-main);"><%= campground.description%></p>
            
            <%  if( currentUser && campground.author.equals(currentUser._id))  {%>
            <div class="d-flex gap-2 mt-3 pt-3 border-top">
                <a class="btn-primary-custom" href="/campgrounds/<%=campground._id%>/edit">
                    <i class="fa-solid fa-pen-to-square me-1"></i> Edit Campground
                </a>
                <form class="d-inline" action="/campgrounds/<%=campground._id%>?_method=DELETE" method="POST">
                    <button class="btn btn-danger py-2 px-4 rounded-pill fw-bold border-0">
                        <i class="fa-solid fa-trash me-1"></i> Delete
                    </button>
                </form>
            </div>
            <% } %>
        </div>
    </div>
    
    <div class="col-lg-6 col-12">
        <div class="mb-4">
            <div id='map'></div>
        </div>

        <% if(currentUser){ %>
        <div class="form-container">
            <h3 class="mb-3">Leave a Review</h3>
            <form action="/campgrounds/<%=campground._id%>/reviews" method="POST" class="validated-form" novalidate>
                <div class="mb-3">
                    <label class="form-label-custom d-block">Rating</label>
                    <fieldset class="starability-basic">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                </div>
                
                <div class="mb-3">
                    <label class="form-label-custom" for="body">Review Text</label>
                    <textarea class="form-control form-control-custom" name="review[body]" id="body" cols="30" rows="3" placeholder="Tell us about your experience..." required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <button class="btn-primary-custom w-100"><i class="fa-solid fa-paper-plane me-1"></i> Submit Review</button>
            </form>
        </div>
        <% } else { %>
        <div class="card card-custom p-4 mb-4 text-center">
            <h5 class="mb-2">Want to leave a review?</h5>
            <p class="text-muted mb-3">You must be logged in to share your experience.</p>
            <a href="/login" class="btn-outline-custom mx-auto">Login to YelpCamp</a>
        </div>
        <% } %>

        <div class="mb-4">
            <h3 class="mb-3"><%= campground.reviews.length %> Reviews</h3>
            <% if(campground.reviews.length === 0) { %>
            <p class="text-muted">No reviews yet. Be the first to share your thoughts!</p>
            <% } %>
            <% for(let review of campground.reviews) { %>
            <div class="review-card">
                <div class="review-header">
                    <span class="review-author"><i class="fa-solid fa-user me-1 text-primary"></i> <%= review.author.username%></span>
                    <p class="starability-result m-0" data-rating="<%=review.rating%>">
                        Rated: <%= review.rating %> stars
                    </p>
                </div>
                <p class="mb-2 text-secondary"><%= review.body %></p>
                <%  if( currentUser && review.author.equals(currentUser._id))  {%>
                <form action="/campgrounds/<%=campground._id%>/reviews/<%=review._id%>?_method=DELETE" method="POST" class="d-flex justify-content-end">
                    <button class="btn btn-sm btn-outline-danger border-0"><i class="fa-solid fa-trash me-1"></i> Delete</button>
                </form>
                <% } %>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
    const campground = <%- JSON.stringify(campground) %>
</script>

<script src="/javascripts/showPageMap.js"></script>