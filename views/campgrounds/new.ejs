<% layout('layouts/boilerplate')%>
<div class="row">
    <div class="col-lg-8 offset-lg-2 col-md-10 offset-md-1 col-12">
        <div class="form-container">
            <h1 class="text-center mb-4"><i class="fa-solid fa-tent text-success me-2"></i>New Campground</h1>
            <form action="/campgrounds" method="POST" novalidate class="validated-form" enctype="multipart/form-data">
                <div class="mb-3">
                    <label class="form-label-custom" for="title">Title</label>
                    <input class="form-control form-control-custom" type="text" id="title" name="campground[title]" placeholder="Enter a descriptive title" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label-custom" for="location">Location</label>
                    <input class="form-control form-control-custom" type="text" id="location" name="campground[location]" placeholder="e.g. Yosemite, California" required>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label-custom" for="price">Campground Price</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" id="price-label" style="border: 1px solid rgba(26, 67, 50, 0.15); border-radius: 8px 0 0 8px;">$</span>
                        <input type="number" class="form-control form-control-custom border-start-0" id="price" placeholder="0.00" aria-label="price"
                            aria-describedby="price-label" name="campground[price]" min="0" step="0.01" style="border-radius: 0 8px 8px 0;" required>
                    </div>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label-custom" for="description">Description</label>
                    <textarea class="form-control form-control-custom" type="text" id="description" name="campground[description]" rows="4" placeholder="Describe the environment, amenities, activities..." required></textarea>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label-custom" for="image">Choose Images</label>
                    <input class="form-control form-control-custom" type="file" id="image" name="image" multiple required>
                    <div class="form-text text-muted">Upload high-quality photos of the campsite.</div>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <button class="btn-primary-custom py-2.5 fs-5 w-100"><i class="fa-solid fa-plus me-1"></i> Add Campground</button>
                </div>
            </form>
            <div class="text-center mt-3">
                <a href="/campgrounds" class="text-success text-decoration-none fw-bold"><i class="fa-solid fa-arrow-left me-1"></i> Back to All Campgrounds</a>
            </div>
        </div>
    </div>
</div>