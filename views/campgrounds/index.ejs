<% layout('layouts/boilerplate')%>
<div id="cluster-map"></div>
<div class="container mb-5">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            <h1 class="mb-1">All Campgrounds</h1>
            <p class="text-muted mb-0">Discover your next destination from our verified campgrounds</p>
        </div>
        <% if(currentUser) { %>
        <a href="/campgrounds/new" class="btn-accent-custom">
            <i class="fa-solid fa-plus me-1"></i> Add Campground
        </a>
        <% } %>
    </div>

    <div class="row">
        <% for (let campground of campgrounds){%>
        <div class="col-xl-4 col-lg-6 col-md-6 col-sm-12">
            <div class="card-custom card h-100">
                <div class="card-img-container">
                    <%if(campground.images.length) {%>
                    <img alt="<%= campground.title %>" src="<%=campground.images[0].url%>" loading="lazy">
                    <% }else {%>
                    <img alt="Default Campground Image"
                        src="https://images.unsplash.com/photo-1478131143081-80f7f84ca84d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" loading="lazy">
                    <% } %>
                    <div class="price-tag">$<%= campground.price %> / night</div>
                </div>
                <div class="card-body d-flex flex-column justify-content-between" style="min-height: 200px;">
                    <div>
                        <h5 class="card-title mb-1"><%= campground.title %></h5>
                        <div class="card-location">
                            <i class="fa-solid fa-location-dot text-danger"></i> <%= campground.location %>
                        </div>
                        <p class="card-text mb-3">
                            <%= campground.description.length > 120 ? campground.description.substring(0, 120) + '...' : campground.description %>
                        </p>
                    </div>
                    <a class="btn-primary-custom text-center w-100" href="/campgrounds/<%=campground._id%>">
                        <i class="fa-solid fa-eye me-1"></i> View <%= campground.title.split(' ')[0] %>
                    </a>
                </div>
            </div>
        </div>
        <% }%>
    </div>
</div>

<script>
    const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
    const campgrounds = { features: <%- JSON.stringify(campgrounds) %>}
</script>

<script src="/javascripts/clusterMap.js"></script>