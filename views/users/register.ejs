<% layout('layouts/boilerplate')%>

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-8 col-sm-10 col-12">
        <div class="form-container mt-4">
            <div class="text-center mb-4">
                <i class="fa-solid fa-user-plus text-success fa-3x mb-2"></i>
                <h2>Create Account</h2>
                <p class="text-muted">Join the YelpCamp community today</p>
            </div>
            
            <form action="/register" method="POST" class="validated-form" novalidate>
                <div class="mb-3">
                    <label class="form-label-custom" for="username">Username</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" id="username-addon" style="border: 1px solid rgba(26, 67, 50, 0.15); border-radius: 8px 0 0 8px;"><i class="fa-solid fa-user text-muted"></i></span>
                        <input class="form-control form-control-custom border-start-0" type="text" id="username" name="username" aria-describedby="username-addon" placeholder="Enter username" style="border-radius: 0 8px 8px 0;" autofocus required>
                    </div>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label-custom" for="email">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" id="email-addon" style="border: 1px solid rgba(26, 67, 50, 0.15); border-radius: 8px 0 0 8px;"><i class="fa-solid fa-envelope text-muted"></i></span>
                        <input class="form-control form-control-custom border-start-0" type="email" id="email" name="email" aria-describedby="email-addon" placeholder="Enter email" style="border-radius: 0 8px 8px 0;" required>
                    </div>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label-custom" for="password">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0" id="password-addon" style="border: 1px solid rgba(26, 67, 50, 0.15); border-radius: 8px 0 0 8px;"><i class="fa-solid fa-lock text-muted"></i></span>
                        <input class="form-control form-control-custom border-start-0" type="password" id="password" name="password" aria-describedby="password-addon" placeholder="Enter password" style="border-radius: 0 8px 8px 0;" required>
                    </div>
                    <div class="valid-feedback">
                        Looks good!
                    </div>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <button class="btn-primary-custom py-2.5 fs-5 w-100"><i class="fa-solid fa-user-plus me-1"></i> Register</button>
                </div>
            </form>
            
            <div class="text-center mt-3 pt-3 border-top">
                <span class="text-muted">Already have an account?</span> 
                <a href="/login" class="text-success text-decoration-none fw-bold ms-1">Login here</a>
            </div>
        </div>
    </div>
</div>