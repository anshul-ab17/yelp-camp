<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YelpCamp | Explore the Great Outdoors</title>
    
    <!-- Bootstrap 5.3.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
        integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />

    <link rel="stylesheet" href="/stylesheets/home.css">
    
    <!-- Outfit Font -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
</head>

<body class="d-flex text-center text-white bg-dark">
    <div class="cover-container d-flex w-100 h-100 p-4 mx-auto flex-column justify-content-between">
        <header class="mb-auto">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                <h3 class="mb-3 mb-md-0 fw-extrabold brand-title"><i class="fa-solid fa-campground text-success me-2"></i>YelpCamp</h3>
                <nav class="nav nav-masthead justify-content-center">
                    <a class="nav-link active" aria-current="page" href="/">Home</a>
                    <a class="nav-link" href="/campgrounds">Campgrounds</a>
                    <% if(!currentUser) { %>
                    <a class="nav-link" href="/login">Login</a>
                    <a class="nav-link btn-register-home" href="/register">Register</a>
                    <% } else { %>
                    <a class="nav-link btn-register-home" href="/logout">Logout</a>
                    <% } %>
                </nav>
            </div>
        </header>
        
        <main class="px-3 my-auto py-5">
            <h1 class="hero-title mb-3">Explore the Great Outdoors</h1>
            <p class="lead hero-text mb-4">
                Welcome to YelpCamp! Discover and share verified campgrounds from all around the world. Write reviews, view maps, upload beautiful photos, and connect with fellow campers.
            </p>
            <a href="/campgrounds" class="btn btn-lg btn-hero-custom py-3 px-5 fw-bold">
                <i class="fa-solid fa-compass me-2"></i> Start Exploring
            </a>
        </main>

        <footer class="mt-auto text-white-50 py-3">
            <p class="mb-0 text-sm">&copy; <%= new Date().getFullYear() %> YelpCamp. Find your next adventure.</p>
        </footer>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</body>

</html>